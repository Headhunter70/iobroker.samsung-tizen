{
  "type": "panel",
  "items": {
    "_header": {
      "type": "header",
      "text": "Samsung Tizen TV – Konfiguration",
      "size": 4
    },
    "ip": {
      "type": "text",
      "label": "TV IP-Adresse",
      "help": "z.B. 192.168.1.100",
      "sm": 12, "md": 6
    },
    "mac": {
      "type": "text",
      "label": "MAC-Adresse (für WakeOnLAN)",
      "help": "z.B. AA:BB:CC:DD:EE:FF",
      "sm": 12, "md": 6
    },
    "port": {
      "type": "number",
      "label": "WebSocket Port",
      "defaultValue": 8001,
      "sm": 12, "md": 4
    },
    "name": {
      "type": "text",
      "label": "Gerätename (am TV angezeigt)",
      "defaultValue": "ioBroker",
      "sm": 12, "md": 4
    },
    "pollInterval": {
      "type": "number",
      "label": "Abfrageintervall (ms)",
      "defaultValue": 5000,
      "sm": 12, "md": 4
    },
    "_tokenHeader": {
      "type": "header",
      "text": "Authentifizierung",
      "size": 5
    },
    "_tokenHelp": {
      "type": "staticText",
      "text": "Beim ersten Start erscheint am TV eine Genehmigungsanfrage. Das Token wird danach automatisch gespeichert."
    },
    "token": {
      "type": "text",
      "label": "Gespeichertes Token (automatisch befüllt)",
      "sm": 12
    }
  }
}
